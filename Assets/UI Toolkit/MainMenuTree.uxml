        <ui:Label text="Vsync" name="Vsyng" class="Textlow" style="top: 764px; left: 823px; width: 122px;"/>
        <ui:SliderInt label="" value="42" high-value="100" name="LockFPSSlider" style="position: absolute; top: 889px; left: 971px; height: 63px; width: 447px;"/>
        <ui:Label text="Ограничение FPS" name="LockFPS" class="Textlow" style="top: 889px; left: 529px;"/>
        <ui:Button text="Назад" name="BackToSettingsMenu" class="button" style="height: 61px; width: 206px; top: 982px; left: 1670px; font-size: 60px; -unity-font-definition: url(&quot;project://database/Assets/Other/sans.ttf?fileID=12800000&amp;guid=37fcb84763fad8e44acd96294dc220d4&amp;type=3#sans&quot;); position: relative; background-color: rgba(0, 0, 0, 0); transition-duration: 0.35s; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;"/>
        <ui:Label text="FPS" name="FPSText" class="Textlow" style="top: 889px; left: 1459px; font-size: 25px;"/>
        <ui:Label text="Полноэкранный режим" name="TextFullscreen" class="Text" style="top: 139px; left: 583px; font-size: 40px;"/>
        <ui:Toggle label="" name="VsyngToggle" style="position: absolute; top: 787px; left: 982px; scale: 1.5 1.5;"/>
        <ui:Toggle label="" name="FullscreenToggle" style="position: absolute; top: 162px; left: 1099px; scale: 1.5 1.5;"/>
        <ui:Label text="Счётчик FPS" name="CounterFPS" class="Textlow" style="top: 1016px; left: 729px; height: 49px; width: 243px;"/>
        <ui:Button text="Выкл" name="CounterFPSButton" class="button" style="font-size: 30px; -unity-font-definition: url(&quot;project://database/Assets/Other/sans.ttf?fileID=12800000&amp;guid=37fcb84763fad8e44acd96294dc220d4&amp;type=3#sans&quot;); top: 1023px; height: 44px; width: 88px; position: absolute; left: 1048px; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;"/>
    </ui:VisualElement>
    <ui:VisualElement name="MenuControl" style="flex-grow: 1; display: none; opacity: 1;"/>
